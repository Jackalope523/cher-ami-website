 in accordance with applicable law.\\u003c/span\\u003e\\u003c/span\\u003e\\u003cdiv class=\\\"MsoNormal\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cspan style=\\\"font-size: 15px;\\\"\\u003e\\u003cbdt class=\\\"statement-end-if-in-editor\\\"\\u003e\\u003c/bdt\\u003e\\u003c/span\\u003e\\u003cbdt class=\\\"block-component\\\"\\u003e\\u003cspan style=\\\"font-size: 15px;\\\"\\u003e\\u003c/span\\u003e\\u003c/bdt\\u003e\\u003cspan style=\\\"font-size: 15px;\\\"\\u003e\\u003cbdt class=\\\"block-component\\\"\\u003e\\u003c/bdt\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" data-custom-class=\\\"heading_1\\\" id=\\\"returnno\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cstrong\\u003e\\u003cspan style=\\\"font-size: 19px; line-height: 1.5;\\\"\\u003e\\u003ch2\\u003e8. \\u003cbdt class=\\\"block-component\\\"\\u003e\\u003c/bdt\\u003eRETURN\\u003cbdt class=\\\"statement-end-if-in-editor\\\"\\u003e\\u003c/bdt\\u003e POLICY\\u003c/h2\\u003e\\u003c/span\\u003e\\u003c/strong\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" data-custom-class=\\\"body_text\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cspan style=\\\"font-size: 15px;\\\"\\u003eAll sales are final and no refund will be issued.\\u003cbdt class=\\\"statement-end-if-in-editor\\\"\\u003e\\u003c/bdt\\u003e\\u003cbdt class=\\\"statement-end-if-in-editor\\\"\\u003e\\u003c/bdt\\u003e\\u003c/span\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cbdt class=\\\"block-component\\\"\\u003e\\u003c/bdt\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv class=\\\"MsoNormal\\\" data-custom-class=\\\"heading_1\\\" id=\\\"software\\\" style=\\\"line-height: 1.5;\\\"\\u003e\\u003cstrong\\u003e\\u003cspan style=\\\"font-size: 19px; line-height: 1.5;\\\"\\u003